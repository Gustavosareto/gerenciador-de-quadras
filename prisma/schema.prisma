generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
  binaryTargets   = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model Customer {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  authUserId      String?           @map("auth_user_id") @db.Uuid
  name            String
  phone           String?           @unique
  email           String?
  cpf             String?
  whatsappOptInAt DateTime?         @map("whatsapp_opt_in_at") @db.Timestamptz(6)
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  users           users?            @relation(fields: [authUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifications   NotificationJob[]
  reservations    Reservation[]

  @@map("customers")
  @@schema("public")
}

model Company {
  id                   String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ownerId              String?           @map("owner_id") @db.Uuid
  name                 String
  slug                 String?           @unique
  planType             String?           @default("FREE") @map("plan_type")
  convenienceFeeMode   String?           @default("FIXED") @map("convenience_fee_mode")
  convenienceFeeValue  Decimal?          @default(2.00) @map("convenience_fee_value") @db.Decimal(10, 2)
  payoutSchedule       String?           @default("WEEKLY_MONDAY") @map("payout_schedule")
  payoutPixKeyType     String?           @map("payout_pix_key_type")
  payoutPixKey         String?           @map("payout_pix_key")
  notificationSettings Json?             @default("{\"enable_whatsapp\": true}") @map("notification_settings")
  balanceAvailable     Decimal?          @default(0.00) @map("balance_available") @db.Decimal(12, 2)
  balancePending       Decimal?          @default(0.00) @map("balance_pending") @db.Decimal(12, 2)
  createdAt            DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  address              String?
  phone                String?
  whatsapp             String?
  email                String?
  instagram            String?
  openingHours         Json?             @map("opening_hours")
  logo                 String?
  stripeCustomerId     String?           @map("stripe_customer_id")
  stripeSubscriptionId String?           @map("stripe_subscription_id")
  addressCep           String?           @map("address_cep")
  addressCity          String?           @map("address_city")
  addressNumber        String?           @map("address_number")
  addressState         String?           @map("address_state")
  addressStreet        String?           @map("address_street")
  users                users?            @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courts               Court[]
  ledgerEntries        LedgerEntry[]
  notifications        NotificationJob[]
  payments             Payment[]
  payouts              Payout[]
  reservations         Reservation[]

  @@map("companies")
  @@schema("public")
}

model Court {
  id                String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyId         String        @map("company_id") @db.Uuid
  name              String
  type              String
  hourlyRate        Decimal       @map("hourly_rate") @db.Decimal(10, 2)
  image             String?
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  reservationType   String        @default("FIXED") @map("reservation_type")
  customAddress     String?       @map("custom_address")
  useCompanyAddress Boolean?      @default(true) @map("use_company_address")
  images            String[]      @default([])
  dimensions        String?       @map("dimensions")
  maxPlayers        Int?          @map("max_players")
  minPlayers        Int?          @map("min_players")
  surface           String?       @map("surface")
  description       String?
  company           Company       @relation(fields: [companyId], references: [id])
  reservations      Reservation[]

  @@index([companyId], map: "idx_courts_company_id")
  @@map("courts")
  @@schema("public")
}

model Reservation {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyId     String            @map("company_id") @db.Uuid
  customerId    String            @map("customer_id") @db.Uuid
  courtId       String            @map("court_id") @db.Uuid
  startAt       DateTime          @map("start_at") @db.Timestamptz(6)
  endAt         DateTime          @map("end_at") @db.Timestamptz(6)
  status        String
  totalPrice    Decimal           @map("total_price") @db.Decimal(10, 2)
  holdExpiresAt DateTime?         @map("hold_expires_at") @db.Timestamptz(6)
  createdAt     DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  notifications NotificationJob[]
  payments      Payment[]
  company       Company           @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  court         Court             @relation(fields: [courtId], references: [id], onDelete: Cascade)
  customer      Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([companyId, startAt, endAt], map: "idx_reservations_company_dates")
  @@index([customerId], map: "idx_reservations_customer")
  @@map("reservations")
  @@schema("public")
}

model Payment {
  id                 String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reservationId      String        @map("reservation_id") @db.Uuid
  companyId          String        @map("company_id") @db.Uuid
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  baseAmount         Decimal       @map("base_amount") @db.Decimal(10, 2)
  serviceFee         Decimal       @map("service_fee") @db.Decimal(10, 2)
  gatewayFee         Decimal?      @default(0.00) @map("gateway_fee") @db.Decimal(10, 2)
  platformNetRevenue Decimal?      @default(0.00) @map("platform_net_revenue") @db.Decimal(10, 2)
  provider           String?       @default("ABACATE_PAY")
  providerChargeId   String?       @map("provider_charge_id")
  pixCopyPaste       String?       @map("pix_copy_paste")
  pixQrCodeUrl       String?       @map("pix_qr_code_url")
  status             String
  expiresAt          DateTime?     @map("expires_at") @db.Timestamptz(6)
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz(6)
  metadata           Json?
  createdAt          DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  ledgerEntries      LedgerEntry[]
  company            Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reservation        Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
  @@schema("public")
}

model WebhookEvent {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  eventId     String    @unique @map("event_id")
  provider    String
  payload     Json
  status      String?   @default("PENDING")
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  errorLog    String?   @map("error_log")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("webhook_events")
  @@schema("public")
}

model LedgerEntry {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  paymentId     String?   @map("payment_id") @db.Uuid
  payoutId      String?   @map("payout_id") @db.Uuid
  type          String
  amount        Decimal   @db.Decimal(12, 2)
  direction     String
  balanceBefore Decimal?  @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal?  @map("balance_after") @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payment       Payment?  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  payout        Payout?   @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  @@map("ledger_entries")
  @@schema("public")
}

model PayoutBatch {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  scheduledDate DateTime  @map("scheduled_date") @db.Date
  status        String?   @default("SCHEDULED")
  totalAmount   Decimal?  @default(0.00) @map("total_amount") @db.Decimal(12, 2)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  payouts       Payout[]

  @@map("payout_batches")
  @@schema("public")
}

model Payout {
  id                 String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  batchId            String?       @map("batch_id") @db.Uuid
  companyId          String?       @map("company_id") @db.Uuid
  amount             Decimal       @db.Decimal(12, 2)
  feeAmount          Decimal?      @default(0.00) @map("fee_amount") @db.Decimal(10, 2)
  status             String?       @default("PENDING")
  bankAccountInfo    Json?         @map("bank_account_info")
  providerTransferId String?       @map("provider_transfer_id")
  attempts           Int?          @default(0)
  lastError          String?       @map("last_error")
  processedAt        DateTime?     @map("processed_at") @db.Timestamptz(6)
  createdAt          DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  ledgerEntries      LedgerEntry[]
  batch              PayoutBatch?  @relation(fields: [batchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company            Company?      @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("payouts")
  @@schema("public")
}

model NotificationJob {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  companyId         String?             @map("company_id") @db.Uuid
  customerId        String?             @map("customer_id") @db.Uuid
  reservationId     String?             @map("reservation_id") @db.Uuid
  type              String
  channel           String?             @default("WHATSAPP")
  templateName      String              @map("template_name")
  variablesJson     Json?               @map("variables_json")
  scheduledAt       DateTime            @map("scheduled_at") @db.Timestamptz(6)
  status            String?             @default("SCHEDULED")
  providerMessageId String?             @map("provider_message_id")
  attempts          Int?                @default(0)
  lastError         String?             @map("last_error")
  createdAt         DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(6)
  events            NotificationEvent[]
  company           Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer?           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reservation       Reservation?        @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt], map: "idx_notify_schedule")
  @@map("notification_jobs")
  @@schema("public")
}

model NotificationEvent {
  id         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  jobId      String?          @map("job_id") @db.Uuid
  status     String
  rawPayload Json?            @map("raw_payload")
  occurredAt DateTime?        @default(now()) @map("occurred_at") @db.Timestamptz(6)
  job        NotificationJob? @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("notification_events")
  @@schema("public")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email     String
  code      String    @db.VarChar(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email, code])
  @@index([expiresAt])
  @@map("password_reset_tokens")
  @@schema("public")
}

